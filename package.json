{
  "name": "@nexifi/mdx-blog",
  "version": "2.0.0",
  "description": "Complete headless blog toolkit — API client, React hooks, SEO components, sitemap, RSS, MDX widgets. Works with Next.js, Remix, Astro, Nuxt, SvelteKit, and any React app.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nexifi-blog": "./dist/cli/index.js",
    "mdx-blog": "./dist/cli/index.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "import": "./dist/mdx.js"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:cli": "tsup --config tsup.cli.config.ts",
    "build:all": "pnpm build && pnpm build:cli",
    "dev": "tsup --watch",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "prepublishOnly": "pnpm test:ci && pnpm build:all",
    "blog:validate": "npx @nexifi/mdx-blog validate",
    "prepare": "husky",
    "prepare": "husky"
  },
  "keywords": [
    "mdx",
    "blog",
    "api",
    "cms",
    "nextjs",
    "remix",
    "astro",
    "nuxt",
    "sveltekit",
    "react",
    "vue",
    "svelte",
    "headless-cms",
    "remote-content",
    "swr",
    "cache",
    "ui-components",
    "seo",
    "sitemap",
    "json-ld"
  ],
  "author": "Nexifi",
  "license": "MIT",
  "homepage": "https://github.com/nexifi/mdx-blog",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexifi/mdx-blog",
    "directory": "packages/mdx-remote-blog"
  },
  "bugs": {
    "url": "https://github.com/nexifi/mdx-blog/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@openai/agents": "^0.3.7",
    "openai": "^5.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@astrojs/react": ">=3.0.0",
    "@mdx-js/react": ">=2.0.0",
    "@remix-run/react": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "next": ">=12.0.0",
    "next-mdx-remote": ">=4.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "rehype-highlight": ">=6.0.0",
    "remark-gfm": ">=3.0.0",
    "swr": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "next-mdx-remote": {
      "optional": true
    },
    "rehype-highlight": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "@mdx-js/react": {
      "optional": true
    },
    "@astrojs/react": {
      "optional": true
    },
    "@remix-run/react": {
      "optional": true
    },
    "@sveltejs/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.7.0",
    "next": "^16.1.6",
    "next-mdx-remote": "^6.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "vitest related --run"
    ]
  },
  "files": [
    "dist",
    "dist/cli",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}